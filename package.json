{
  "name": "showroom",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "scripts": {
    "next:dev": "pnpm --filter nextjs-playground run dev",
    "next:start": "pnpm --filter nextjs-playground run start",
    "next:build": "pnpm --filter nextjs-playground run build",
    "tanstack:dev": "pnpm --filter tanstack-playground run dev",
    "tanstack:build": "pnpm --filter tanstack-playground run build",
    "tanstack:preview": "pnpm --filter tanstack-playground run preview",
    "astro:dev": "pnpm --filter astro-playground run dev",
    "astro:build": "pnpm --filter astro-playground run build",
    "astro:preview": "pnpm --filter astro-playground run preview",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "preinstall": "npx -y only-allow pnpm",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.61.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,md,css,html,yaml,yml}": [
      "oxfmt"
    ]
  }
}
