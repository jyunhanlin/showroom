{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "extends": ["../../.oxlintrc.json"],
  "plugins": ["react", "nextjs"],
  "rules": {
    "react/react-in-jsx-scope": "off",
    "nextjs/no-img-element": "off",
    "import/no-unassigned-import": ["warn", { "allow": ["**/*.css"] }]
  }
}
