{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "typescript", "unicorn", "jsx-a11y"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "rules": {
    "import/no-default-export": "off",
    "import/no-named-as-default": "off",
    "jsx-a11y/alt-text": "warn"
  },
  "ignorePatterns": [
    "**/node_modules",
    "**/.next",
    "**/out",
    "**/dist",
    "**/build",
    "**/coverage",
    "**/.husky",
    "pnpm-lock.yaml"
  ]
}
